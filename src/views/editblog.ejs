<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>Edit Blog - <%= blog.title %></title>
  </head>
  <body>
    <%- include('./partials/nav') %>
    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card p-4 p-md-5 shadow-sm border-0">
            <div class="d-flex justify-content-between align-items-center mb-4">
              <h2 class="fw-bold m-0">Edit Blog</h2>
              <a href="/blog/delete/<%= blog._id %>" 
                 class="btn btn-outline-danger btn-sm fw-semibold"
                 onclick="return confirm('Are you sure you want to delete this blog?')">
                Delete Blog
              </a>
            </div>
            
            <p class="text-muted mb-4">
              Editing: <strong><%= blog.title %></strong>
            </p>

            <form action="/blog/update/<%= blog._id %>" method="POST" enctype="multipart/form-data">
              <div class="mb-4 text-center">
                <% if (blog.coverImageURL) { %>
                  <img src="<%= blog.coverImageURL %>" alt="Current Cover" class="img-fluid rounded mb-3" style="max-height: 200px; object-fit: cover;">
                <% } %>
                <div class="text-start">
                  <label for="coverImage" class="form-label small fw-semibold">Update Cover Image</label>
                  <input type="file" class="form-control" id="coverImage" name="coverImage" />
                  <div class="form-text mt-2 small text-muted">
                    Leave blank to keep the current cover image.
                  </div>
                </div>
              </div>

              <div class="mb-4">
                <label for="title" class="form-label small fw-semibold">Title</label>
                <input
                  type="text"
                  class="form-control form-control-lg"
                  id="title"
                  name="title"
                  value="<%= blog.title %>"
                  required
                />
              </div>

              <div class="mb-4">
                <label for="body" class="form-label small fw-semibold">Content</label>
                <textarea
                  name="body"
                  class="form-control"
                  id="body"
                  rows="10"
                  required
                ><%= blog.body %></textarea>
              </div>

              <div class="d-flex justify-content-end gap-2 mt-4">
                <a href="/blog/<%= blog._id %>" class="btn btn-light fw-semibold px-4">Cancel</a>
                <button type="submit" class="btn btn-primary fw-semibold px-4">
                  Save Changes
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
    <%- include('./partials/scripts') %>
  </body>
</html>
