<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title><%= blog.title %></title>
  </head>
  <body>
    <%- include('./partials/nav') %>
    <div class="container py-4 py-md-5">
      <div class="row justify-content-center">
        <div class="col-lg-9">
          <!-- Back Button -->
          <div class="mb-4">
            <a href="/" class="btn btn-link text-decoration-none text-muted p-0 d-flex align-items-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left me-2" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
              </svg>
              Back to Home
            </a>
          </div>

          <div class="card border-0 shadow-sm overflow-hidden">
            <% if (blog.coverImageURL) { %>
              <img src="<%= blog.coverImageURL %>" class="card-img-top" alt="<%= blog.title %>" style="height: auto; max-height: 500px; object-fit: cover; width: 100%;">
            <% } %>
            <div class="card-body p-4 p-md-5">
              <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="fw-bold display-5 m-0"><%= blog.title %></h1>
                <% if (user && (user._id.toString() === blog.createdBy.toString() || user.role === 'admin')) { %>
                  <div class="d-flex gap-2">
                    <a href="/blog/edit/<%= blog._id %>" class="btn btn-outline-primary fw-semibold px-4">Edit</a>
                    <a href="/blog/delete/<%= blog._id %>" 
                       class="btn btn-outline-danger fw-semibold px-4"
                       onclick="return confirm('Are you sure you want to delete this blog?')">
                      Delete
                    </a>
                  </div>
                <% } %>
              </div>
              
              <div class="blog-content lead text-dark">
                <%- blog.body.replace(/\n/g, '<br>') %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <%- include('./partials/scripts') %>
  </body>
</html>
