<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>dashboard</title>
  </head>
  <body>
    <%- include('./partials/nav') %>
    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
    <div class="container py-5">
      <div class="row">
        <div class="col-12">
          <!-- User Management -->
          <div class="card p-4 shadow-sm border-0 mb-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
              <h2 class="fw-bold mb-0">User Management</h2>
              <span class="badge bg-primary px-3 py-2">Total Users: <%= users.length %></span>
            </div>
            
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead class="table-light">
                  <tr>
                    <th>User</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (locals.users && users.length > 0) { %>
                    <% users.forEach(u => { %>
                      <tr id="user-<%= u._id %>">
                        <td>
                          <div class="d-flex align-items-center">
                            <img src="<%= u.profileImageUrl %>" alt="" class="rounded-circle me-3" style="width: 40px; height: 40px; object-fit: cover;">
                            <span class="fw-semibold"><%= u.username %></span>
                          </div>
                        </td>
                        <td><%= u.email %></td>
                        <td>
                          <span class="badge rounded-pill <%= u.role === 'admin' ? 'bg-danger' : 'bg-secondary' %>">
                            <%= u.role %>
                          </span>
                        </td>
                        <td class="text-end">
                          <a href="/dashboard/edit/<%= u._id %>" class="btn btn-sm btn-outline-primary me-2">Update</a>
                          <button onclick="deleteUser('<%= u._id %>')" class="btn btn-sm btn-outline-danger">Delete</button>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="4" class="text-center py-4 text-muted">No users found</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Blog Management -->
          <div class="card p-4 shadow-sm border-0">
            <div class="d-flex justify-content-between align-items-center mb-4">
              <h2 class="fw-bold mb-0">Blog Management</h2>
              <span class="badge bg-success px-3 py-2">Total Blogs: <%= blogs.length %></span>
            </div>
            
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead class="table-light">
                  <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Date</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (locals.blogs && blogs.length > 0) { %>
                    <% blogs.forEach(b => { %>
                      <tr>
                        <td>
                          <div class="fw-semibold text-truncate" style="max-width: 250px;">
                            <a href="/blog/<%= b._id %>" class="text-decoration-none text-dark"><%= b.title %></a>
                          </div>
                        </td>
                        <td>
                          <span class="text-muted"><%= b.createdBy ? b.createdBy.username : 'Unknown' %></span>
                        </td>
                        <td>
                          <span class="text-muted small"><%= new Date(b.createdAt).toLocaleDateString() %></span>
                        </td>
                        <td class="text-end">
                          <a href="/blog/edit/<%= b._id %>" class="btn btn-sm btn-outline-primary me-2">Edit</a>
                          <a href="/blog/delete/<%= b._id %>" 
                             class="btn btn-sm btn-outline-danger"
                             onclick="return confirm('Are you sure you want to delete this blog?')">Delete</a>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="4" class="text-center py-4 text-muted">No blogs found</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      async function deleteUser(id) {
        if (confirm('Are you sure you want to delete this user?')) {
          try {
            const response = await fetch(`/dashboard/delete/${id}`, {
              method: 'DELETE',
            });
            if (response.ok) {
              window.location.reload();
            } else {
              alert('Failed to delete user');
            }
          } catch (error) {
            console.error('Error:', error);
            alert('An error occurred');
          }
        }
      }
    </script>
        </div>
      </div>
    </div>
    <%- include('./partials/scripts') %>
  </body>
</html>
